gpu:
  enabled: false
  pluginVersion: v0.17.0

nfs:
  server: your-nfs-hostname
  path: /mnt/nfs/k3s

domain: home.example.com

acme:
  email: you@example.com

cloudflare:
  apiToken: your-cloudflare-api-token

k3s:
  podCIDR: 10.42.0.0/16
  serviceCIDR: 10.43.0.0/16

external-dns:
  provider:
    name: cloudflare
  env:
    - name: CF_API_TOKEN
      valueFrom:
        secretKeyRef:
          name: cloudflare-api-token
          key: cf_api_token
  sources:
    - ingress
    - node
  domainFilters:
    - example.com
  policy: sync
  txtOwnerId: home-prod

homeAssistant:
  enabled: true
  version: "2025.4"
  storage: 5Gi
  timezone: America/Los_Angeles

ollama:
  enabled: true
  version: latest
  storage: 50Gi
  gpu: false
  models:
    - qwen3.5:27b

openclaw:
  enabled: true
  version: latest
  storage: 64Gi
  model: qwen3.5:27b
  timeoutSeconds: 600
  gatewayToken: your-gateway-token
  discordToken: your-discord-bot-token
  discordAllowedUsers:
    - "your-discord-user-id"
